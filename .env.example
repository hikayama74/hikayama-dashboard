# Firebase 設定（Firebase コンソール > プロジェクト設定 > マイアプリ から取得）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API キー（雑入力モーダル / AIに聞く で使用。無料枠あり=1日1,500リクエスト）
# 取得: https://aistudio.google.com/apikey
# ⚠️ フロントに置くため、ビルド成果物（公開サイト）にキーが含まれ第三者に露出します。
#    当面の運用方針。将来は Cloud Functions 経由に移行してキーをサーバ側に隠す想定。
VITE_GEMINI_API_KEY=
