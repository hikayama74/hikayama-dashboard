# Firebase 設定（Firebase コンソール > プロジェクト設定 > マイアプリ から取得）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini API キー（雑入力モーダル / AIに聞く で使用）
# ※ 無料枠はモデルごとに1日の上限あり（2.5-flash/lite ともに1日20回程度と低い）。上限超過時は429。
#    恒久対策は Google Cloud で課金を有効化（上限大幅増）または Cloud Functions 化（フェーズ2）。
# 取得: https://aistudio.google.com/apikey
# ⚠️ フロントに置くため、ビルド成果物（公開サイト）にキーが含まれ第三者に露出します。
#    当面の運用方針。将来は Cloud Functions 経由に移行してキーをサーバ側に隠す想定。
VITE_GEMINI_API_KEY=

# 使用モデル（任意）。未設定なら gemini-2.5-flash-lite。
# 無料枠の日次上限を試したい時に切替: 例) gemini-2.0-flash, gemini-2.5-flash
VITE_GEMINI_MODEL=
