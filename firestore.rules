rules_version = '2';

// データは /users/{userId}/ 配下にユーザーごとに格納する（CLAUDE.md スキーマ準拠）。
// 各ユーザーは自分のドキュメントツリーのみ読み書き可能。
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // tasks / events / memos などのサブコレクションすべてに同じ条件を適用
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
